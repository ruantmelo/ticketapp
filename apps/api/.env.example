NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
DATABASE_URL=./data/ticket-chain.db
UPLOAD_DIR=./data/uploads
JWT_SECRET=dev-secret-change-me-in-production
COOKIE_DOMAIN=localhost
WEB_ORIGIN=http://localhost:5173

# Default local development keeps minting mocked. Set to true to use real contracts.
ONCHAIN_MINTING_ENABLED=false

# Polygon Amoy testnet configuration.
CHAIN_RPC_URL=https://rpc-amoy.polygon.technology/
CHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
CHAIN_ID=80002
TICKET_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
TICKET_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
TICKET_BASE_URI=https://example.com/metadata/
AMOY_MAX_SYNC_SUPPLY=1000

# Local Anvil/Hardhat alternative. Use this with `docker compose up -d anvil`
# or with `npx hardhat node`.
# ONCHAIN_MINTING_ENABLED=true
# CHAIN_RPC_URL=http://127.0.0.1:8545
# CHAIN_PRIVATE_KEY=0xPRIVATE_KEY_FROM_LOCAL_NODE_ACCOUNT
# CHAIN_ID=31337
# TICKET_FACTORY_ADDRESS=0xFACTORY_FROM_DEPLOY_SCRIPT
# TICKET_MARKETPLACE_ADDRESS=0xMARKETPLACE_FROM_DEPLOY_SCRIPT
# TICKET_BASE_URI=http://localhost:4000/metadata/
# AMOY_MAX_SYNC_SUPPLY=1000

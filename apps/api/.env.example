NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
DATABASE_URL=./data/ticket-chain.db
UPLOAD_DIR=./data/uploads
JWT_SECRET=dev-secret-change-me-in-production
COOKIE_DOMAIN=localhost
WEB_ORIGIN=http://localhost:5173

# Default local development keeps minting mocked. Set to true to use real contracts.
ONCHAIN_MINTING_ENABLED=false

# Local Hardhat/Anvil configuration for the local-dev custodial wallet provider.
CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
VALIDATOR_RELAYER_PRIVATE_KEY=0xYOUR_VALIDATOR_RELAYER_PRIVATE_KEY
CHAIN_ID=31337
TICKET_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
TICKET_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Local-dev custody is only for local/testing flows. It exports private keys to
# the browser only when explicitly enabled and must never be used for production
# or real events/funds.
CUSTODIAL_WALLET_PROVIDER=local-dev
ALLOW_LOCAL_CUSTODIAL_PROVIDER=true
ALLOW_PRIVATE_KEY_BOOTSTRAP=true
ALLOW_TESTNET_LOCAL_CUSTODY=false
LOCAL_CUSTODY_MASTER_KEY=dev-change-me-32-byte-minimum-local-secret

TICKET_BASE_URI=http://localhost:4000/metadata/
AMOY_MAX_SYNC_SUPPLY=1000
REDIS_URL=redis://127.0.0.1:6379
MINTING_QUEUE_CONCURRENCY=1
BULL_BOARD_ENABLED=true
BULL_BOARD_BASE_PATH=/admin/queues
BULL_BOARD_ALLOW_REMOTE=false
    
# Polygon Amoy alternative. Requires explicit local custody testnet opt-in and
# must not be used for production custody.
# ONCHAIN_MINTING_ENABLED=true
# CHAIN_RPC_URL=https://rpc-amoy.polygon.technology/
# CHAIN_PRIVATE_KEY=0xPRIVATE_KEY_FROM_TESTNET_ACCOUNT
# VALIDATOR_RELAYER_PRIVATE_KEY=0xPRIVATE_KEY_FROM_AUTHORIZED_VALIDATOR_RELAYER
# CHAIN_ID=80002
# TICKET_FACTORY_ADDRESS=0xFACTORY_FROM_DEPLOY_SCRIPT
# TICKET_MARKETPLACE_ADDRESS=0xMARKETPLACE_FROM_DEPLOY_SCRIPT
# PAYMENT_TOKEN_ADDRESS=0xPAYMENT_TOKEN_ADDRESS
# ALLOW_TESTNET_LOCAL_CUSTODY=true
# ALLOW_PRIVATE_KEY_BOOTSTRAP=true
# TICKET_BASE_URI=http://localhost:4000/metadata/
# AMOY_MAX_SYNC_SUPPLY=1000
